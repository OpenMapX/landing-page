# Legal / operator details, baked into the static pages at BUILD time.
#
# Copy this file to `.env` (gitignored) and fill in real values, then build the
# image. The site is statically prerendered, so these are fixed at build time —
# rebuild to change them. The values are public (they appear in the Legal
# Notice / Privacy Policy), but live in env rather than the repo so the public
# source carries no personal address.

# Operator (Anbieter) — name and postal address
PUBLIC_LEGAL_NAME=
PUBLIC_LEGAL_STREET=
PUBLIC_LEGAL_POSTAL_CODE=
PUBLIC_LEGAL_CITY=
PUBLIC_LEGAL_COUNTRY=

# Contact email shown in the Legal Notice / Terms (default: hello@openmapx.org)
PUBLIC_LEGAL_EMAIL=
# Email shown in the Privacy Policy (default: privacy@openmapx.org)
PUBLIC_LEGAL_PRIVACY_EMAIL=
# Email shown in the Trademark Policy (default: trademark@openmapx.org)
PUBLIC_LEGAL_TRADEMARK_EMAIL=
# Hosting provider shown in the Privacy Policy as an Art. 28 processor (only if a
# third party hosts the static site; leave blank if you host it yourself).
PUBLIC_LEGAL_HOSTING_PROVIDER=
PUBLIC_LEGAL_HOSTING_LOCATIONS=

# Person responsible for content, § 18(2) MStV
PUBLIC_LEGAL_RESPONSIBLE=

# Governing-law jurisdiction shown in the Terms (default: Germany)
PUBLIC_LEGAL_JURISDICTION=

# Server-log retention in days, shown in the Privacy Policy (default: 30)
PUBLIC_LEGAL_LOG_RETENTION_DAYS=
